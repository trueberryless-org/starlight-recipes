---
import { Code } from "@astrojs/starlight/components";

const managers = [
  { id: "npm", base: "npx astro add" },
  { id: "pnpm", base: "pnpm astro add" },
  { id: "yarn", base: "yarn astro add" },
];

const adapters = ["Cloudflare", "Netlify", "Node", "Vercel"];

const allCommands = managers.flatMap((m) =>
  adapters.map((a) => ({
    id: `${m.id}-${a.toLowerCase()}`,
    cmd: `${m.base} ${a.toLowerCase()}`,
  }))
);
---

<adapter-installer class="installer-wrapper not-prose not-content">
  <div class="controls">
    <div class="selector">
      {
        managers.map((m) => (
          <button class="pill pkg-btn" data-value={m.id}>
            {m.id}
          </button>
        ))
      }
    </div>
    <div class="divider"></div>
    <div class="selector">
      {
        adapters.map((a) => (
          <button class="pill adapter-btn" data-value={a.toLowerCase()}>
            {a}
          </button>
        ))
      }
    </div>
  </div>

  <div class="code-stack">
    {
      allCommands.map((c) => (
        <div class="command-variant" data-id={c.id} style="display: none">
          <Code code={c.cmd} lang="sh" />
        </div>
      ))
    }
  </div>
</adapter-installer>

<script>
  class AdapterInstaller extends HTMLElement {
    static PKG_KEY = "starlight-synced-tabs__pkg";
    static ADAPTER_KEY = "starlight-synced-tabs__adapter";
    _bound = false;
    _onStorage = (e: any) => {
      if (
        e.key === AdapterInstaller.PKG_KEY ||
        e.key === AdapterInstaller.ADAPTER_KEY
      ) {
        this.updateUI();
      }
    };

    connectedCallback() {
      this.updateUI();
      if (!this._bound) {
        this._bound = true;
        this.querySelectorAll(".pkg-btn").forEach((btn) => {
          btn.addEventListener("click", () =>
            this.save(AdapterInstaller.PKG_KEY, btn.getAttribute("data-value")!)
          );
        });

        this.querySelectorAll(".adapter-btn").forEach((btn) => {
          btn.addEventListener("click", () =>
            this.save(
              AdapterInstaller.ADAPTER_KEY,
              btn.getAttribute("data-value")!
            )
          );
        });

        window.addEventListener("storage", this._onStorage);
      }
    }

    disconnectedCallback() {
      window.removeEventListener("storage", this._onStorage);
    }

    save(key: string, value: string) {
      localStorage.setItem(key, value);
      window.dispatchEvent(
        new StorageEvent("storage", { key, newValue: value })
      );
    }

    updateUI() {
      const pkg = localStorage.getItem(AdapterInstaller.PKG_KEY) || "npm";
      const adapter =
        localStorage.getItem(AdapterInstaller.ADAPTER_KEY) || "netlify";
      const targetId = `${pkg}-${adapter}`;

      this.querySelectorAll(".command-variant").forEach((v) => {
        (v as HTMLElement).style.display =
          (v as HTMLElement).dataset.id === targetId ? "block" : "none";
      });

      this.querySelectorAll(".pkg-btn").forEach((btn) => {
        btn.classList.toggle("active", btn.getAttribute("data-value") === pkg);
      });

      this.querySelectorAll(".adapter-btn").forEach((btn) => {
        btn.classList.toggle(
          "active",
          btn.getAttribute("data-value") === adapter
        );
      });
    }
  }

  if (!customElements.get("adapter-installer")) {
    customElements.define("adapter-installer", AdapterInstaller);
  }
</script>

<style>
  .installer-wrapper {
    margin: 1.5rem 0;
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 0.75rem;
    background-color: var(--sl-color-gray-7);
    padding: 1rem;
    display: block;
  }
  .controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .selector {
    display: flex;
    gap: 0.25rem;
    background: var(--sl-color-gray-6);
    padding: 0.2rem;
    border-radius: 0.5rem;
  }
  .pill {
    background: transparent;
    border: none;
    color: var(--sl-color-gray-3);
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: 0.4rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .pill:hover {
    color: var(--sl-color-white);
  }
  .pill.active {
    background: var(--sl-color-accent-high);
    color: var(--sl-color-black);
  }
  :global([data-theme="light"]) .pill.active {
    background: var(--sl-color-accent);
  }
  .divider {
    width: 1px;
    height: 1.5rem;
    background: var(--sl-color-gray-5);
  }
</style>
