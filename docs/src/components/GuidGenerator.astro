---
import { Code } from "@astrojs/starlight/components";

const placeholder = "CLICK_GENERATE_TO_CREATE_SECRET";
const codeSnippet = `STARLIGHT_RECIPES_RATING_SECRET=${placeholder}`;
---

<secret-generator
  data-placeholder={placeholder}
  class="magic-container not-content"
>
  <button
    type="button"
    data-gen-btn
    class="magic-button"
    aria-label="Generate new secret"
  >
    <span class="magic-text">Generate Magic Secret</span>
  </button>

  <div data-code-container class="code-stable-container">
    <Code code={codeSnippet} lang="bash" title=".env" />
  </div>
</secret-generator>

<script>
  class SecretGenerator extends HTMLElement {
    private placeholder: string;
    private uuidRegex: RegExp;
    private btn: HTMLButtonElement | null = null;
    private container: HTMLElement | null = null;
    private handleClick: () => void;

    constructor() {
      super();
      this.placeholder = this.dataset.placeholder || "";
      this.uuidRegex =
        /[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/i;
      this.handleClick = this.onGenerateRequest.bind(this);
    }

    connectedCallback() {
      this.btn = this.querySelector<HTMLButtonElement>("[data-gen-btn]");
      this.container = this.querySelector<HTMLElement>("[data-code-container]");

      if (this.btn) {
        this.btn.addEventListener("click", this.handleClick);
      }
    }

    disconnectedCallback() {
      if (this.btn) {
        this.btn.removeEventListener("click", this.handleClick);
      }
    }

    private onGenerateRequest() {
      if (!this.container) return;

      const spans = this.container.querySelectorAll("span");
      const targetSpan = this.findTargetSpan(spans);

      if (targetSpan) {
        this.executeSecretUpdate(targetSpan);
      }
    }

    private findTargetSpan(
      spans: NodeListOf<HTMLSpanElement> | HTMLSpanElement[]
    ) {
      return Array.from(spans).find((span) => {
        const text = span.textContent || "";
        return text.includes(this.placeholder) || this.uuidRegex.test(text);
      });
    }

    private executeSecretUpdate(span: HTMLSpanElement) {
      const newSecret = crypto.randomUUID();
      const previousText = span.textContent || "";

      span.textContent = newSecret;

      this.updateCopyButtonState(previousText, newSecret);
      this.triggerSuccessEffect(span);
    }

    private updateCopyButtonState(oldText: string, newText: string) {
      const copyBtn = this.container?.querySelector(
        ".copy button"
      ) as HTMLElement;
      const currentCode = copyBtn?.dataset.code;

      if (copyBtn && currentCode) {
        copyBtn.dataset.code = currentCode.replace(oldText, newText);
      }
    }

    private triggerSuccessEffect(element: HTMLElement) {
      const accentColor = "var(--sl-color-text-accent)";
      const keyframes = [
        { filter: "brightness(3) blur(2px)", transform: "scale(1.1)" },
        { filter: "brightness(1) blur(0px)", transform: "scale(1)" },
      ];
      const options: KeyframeAnimationOptions = {
        duration: 400,
        easing: "ease-out",
      };

      element.style.color = accentColor;
      element.animate(keyframes, options);
    }
  }

  customElements.define("secret-generator", SecretGenerator);
</script>

<style>
  .magic-container {
    margin: 1.5rem 0;
    display: block;
  }

  .magic-button {
    position: relative;
    cursor: pointer;
    padding: 6px 16px;
    font-size: 0.8rem;
    font-weight: 700;
    color: white;
    background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
    border: none;
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 4px 15px rgba(124, 58, 237, 0.4);
    margin-bottom: 1rem;
    display: inline-block;
  }

  .magic-button:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.6);
  }

  .magic-button:active {
    transform: translateY(0) scale(1);
  }

  .magic-button::after {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      to bottom right,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.1) 40%,
      rgba(255, 255, 255, 0.6) 50%,
      rgba(255, 255, 255, 0.1) 60%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: rotate(45deg);
    animation: magic-shimmer 4s infinite;
  }

  @keyframes magic-shimmer {
    0% {
      transform: translateX(-100%) rotate(45deg);
    }
    20%,
    100% {
      transform: translateX(100%) rotate(45deg);
    }
  }

  .code-stable-container {
    min-height: 4.5rem;
  }

  :global(.code-stable-container span) {
    transition: color 0.4s ease;
  }
</style>
