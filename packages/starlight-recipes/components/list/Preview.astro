---
import context from "virtual:starlight-recipes/context";

import type { StarlightRecipeEntry } from "../../libs/types";
import type { Locale } from "../../libs/i18n";
import { getPathWithLocale, getRelativeUrl } from "../../libs/page";

import Authors from "./../metadata/Authors.astro";
import Cover from "../metadata/Cover.astro";
import Rating from "../metadata/Rating.astro";
import Categories from "../taxonomy/Categories.astro";
import Cuisines from "../taxonomy/Cuisines.astro";
import Flexbox from "../ui/Flexbox.astro";

interface Props {
  entry: StarlightRecipeEntry;
  locale: Locale;
  bigPreview?: boolean;
}

const { entry, locale, bigPreview } = Astro.props;
const url = getRelativeUrl(`/${getPathWithLocale(entry.id, locale)}`);
const headingId = `recipe-title-${entry.id.replace(/[^a-zA-Z0-9]/g, "-")}`;
---

<a
  href={url}
  class={`card-link ${bigPreview ? "big" : "small"}`}
  aria-labelledby={headingId}
>
  <article class="preview-card">
    {
      entry.data.cover && (
        <div class="cover-wrapper">
          <Cover
            cover={entry.data.cover}
            aspectRatio="16/9"
            featured={entry.data.featured ?? false}
          />
        </div>
      )
    }

    <div class="card-content">
      {!bigPreview && <h2 id={headingId}>{entry.data.title}</h2>}
      {
        bigPreview && (
          <div class="big-preview-meta">
            <div class="space-between">
              <h2 id={headingId}>{entry.data.title}</h2>
              {context.ratingEnabled && <Rating recipeId={entry.id} />}
            </div>
            <Authors entry={entry} />

            {entry.data.description && (
              <div class="sl-markdown-content description">
                {entry.data.description}
              </div>
            )}
          </div>
        )
      }

      <div class="blobs-wrapper">
        <Flexbox>
          <Cuisines {entry} {locale} />
          <Categories {entry} {locale} />
        </Flexbox>
      </div>
    </div>
  </article>
</a>

<style>
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.2s ease-in-out;
  }

  .card-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
    border-radius: 20px;
  }

  .preview-card {
    display: flex;
    flex-direction: column;
    --card-bg: #1d1f26;
    background-color: var(--card-bg);
    border-radius: 19px;
    margin-block: 1rem;
  }

  :global([data-theme="light"]) .preview-card {
    --card-bg: #f5f6f8;
  }

  .cover-wrapper {
    width: 100%;
    margin: 0;
    transform: scale(1.02);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex-grow: 1;
  }

  h2 {
    margin: 0;
    color: var(--sl-color-white);
  }

  .small h2 {
    font-size: 1.25rem;
    line-height: 1.4;
  }

  .big h2 {
    font-size: 1.6rem;
    line-height: 1.3;
  }

  .big-preview-meta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .space-between {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .description {
    font-size: 0.95rem;
    color: var(--sl-color-gray-2);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blobs-wrapper {
    margin-top: auto;
  }
</style>
