---
import type {
  StarlightRecipeEntry,
  StarlightRecipeEntryPaginated,
} from "../../libs/content";
import type { Locale } from "../../libs/i18n";
import PrevNextLinks from "../starlight/PrevNextLinks.astro";
import Categories from "../taxonomy/Categories.astro";
import Cuisines from "../taxonomy/Cuisines.astro";

import Tags from "../taxonomy/Tags.astro";
import Flexbox from "../ui/Flexbox.astro";

interface Props {
  entry: StarlightRecipeEntry;
  locale: Locale;
  nextLink: StarlightRecipeEntryPaginated["nextLink"];
  prevLink: StarlightRecipeEntryPaginated["prevLink"];
}

const { entry, locale, nextLink, prevLink } = Astro.props;
---

<div class="recipe-footer">
  <Flexbox>
    <Cuisines {entry} {locale} />
    <Categories {entry} {locale} />
  </Flexbox>
  <Tags {entry} {locale} />
  <PrevNextLinks next={nextLink} prev={prevLink} />
</div>

<style>
  .recipe-footer {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-block-start: 2rem;
  }
</style>
