---
import type { StarlightRecipeEntry } from "../../libs/types";

import Authors from "./Authors.astro";

interface Props {
  entry: StarlightRecipeEntry;
}

const { entry } = Astro.props;
---

<div class="metadata not-content">
  <Authors entry={entry} />
</div>

<style>
  .metadata {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  @media print {
    .metadata {
      margin-top: 0.25rem;
      gap: 0.5rem;
    }
  }
</style>
