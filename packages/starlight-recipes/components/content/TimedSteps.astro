---
import type { StarlightRecipesInstructionStepSchema } from "../../schema";

type Props = {
  steps: StarlightRecipesInstructionStepSchema[];
};

const { steps } = Astro.props;

console.log(steps);

const normalizeStep = (step: StarlightRecipesInstructionStepSchema) => {
  if (typeof step === "string") return { text: step };
  return step;
};

// New helper for natural language duration
const formatNaturalTime = (totalMinutes: number) => {
  const hours = Math.floor(totalMinutes / 60);
  const minutes = totalMinutes % 60;

  // Exact hours (e.g., "12 h")
  if (hours > 0 && minutes === 0) return `${hours} h`;
  // Hours and minutes (e.g., "1 h 30 min")
  if (hours > 0) return `${hours} h ${minutes} min`;
  // Just minutes (e.g., "30 min")
  return `${minutes} min`;
};
---

<ol class="sl-steps sl-steps-interactive not-content">
  {
    steps.map((rawStep, index) => {
      const step = normalizeStep(rawStep);
      const stepNum = index + 1;
      const hasTimer = typeof step.time === "number";

      return (
        <li class={hasTimer ? "is-timed" : ""}>
          {hasTimer ? (
            <step-timer data-time={step.time} data-step={stepNum}>
              <button
                class="timer-pill"
                aria-label={`Start ${step.time} minute timer`}
              >
                <span class="pill-left">
                  <span class="step-index">{stepNum}</span>
                  <span class="icon-play">
                    <svg
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      height="1rem"
                      width="1rem"
                    >
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </span>
                  <span class="icon-pause">
                    <svg
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      height="1rem"
                      width="1rem"
                    >
                      <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
                    </svg>
                  </span>
                </span>
                <span class="pill-right">
                  {/* We now render the natural text initially */}
                  <span class="time-display">
                    {formatNaturalTime(step.time!)}
                  </span>
                </span>
              </button>
              <div class="step-content">
                {step.name && <strong>{step.name}</strong>}
                <p set:html={step.text} />
                {step.image && <img src={step.image} alt={step.alt || ""} />}
              </div>
            </step-timer>
          ) : (
            <div class="step-content">
              {step.name && <strong>{step.name}</strong>}
              <p set:html={step.text} />
              {step.image && <img src={step.image} alt={step.alt || ""} />}
            </div>
          )}
        </li>
      );
    })
  }
</ol>

<script>
  class StepTimer extends HTMLElement {
    private button: HTMLButtonElement | null;
    private display: HTMLSpanElement | null;
    private durationMinutes: number;
    private remainingSeconds: number;
    private interval: number | null = null;
    private isRunning: boolean = false;

    constructor() {
      super();
      this.button = this.querySelector(".timer-pill");
      this.display = this.querySelector(".time-display");
      this.durationMinutes = parseFloat(this.dataset.time || "0");
      this.remainingSeconds = this.durationMinutes * 60;
    }

    connectedCallback() {
      this.button?.addEventListener("click", this.toggleTimer.bind(this));
    }

    toggleTimer() {
      if (this.isRunning) {
        this.pause();
      } else {
        this.start();
      }
    }

    start() {
      if (this.remainingSeconds <= 0) {
        this.remainingSeconds = this.durationMinutes * 60;
      }

      this.isRunning = true;
      this.classList.add("running");
      this.button?.classList.add("active");

      this.updateDisplay();

      this.interval = window.setInterval(() => {
        this.remainingSeconds--;
        this.updateDisplay();

        if (this.remainingSeconds <= 0) {
          this.finish();
        }
      }, 1000);
    }

    pause() {
      this.isRunning = false;
      this.classList.remove("running");
      this.button?.classList.remove("active");
      if (this.interval) clearInterval(this.interval);
    }

    finish() {
      this.pause();
      if (this.display) this.display.textContent = "Done!";
    }

    updateDisplay() {
      if (!this.display) return;

      const h = Math.floor(this.remainingSeconds / 3600);
      const m = Math.floor((this.remainingSeconds % 3600) / 60);
      const s = this.remainingSeconds % 60;

      if (h > 0) {
        this.display.textContent = `${h}:${m.toString().padStart(2, "0")}:${s.toString().padStart(2, "0")}`;
      } else {
        this.display.textContent = `${m}:${s.toString().padStart(2, "0")}`;
      }
    }
  }

  customElements.define("step-timer", StepTimer);
</script>

<style>
  .sl-steps-interactive {
    list-style: none;
    padding-inline-start: 0;
    counter-reset: steps-counter 0;
  }

  .sl-steps-interactive > li {
    position: relative;
    padding-inline-start: 3rem;
    padding-bottom: 1.5rem;
    min-height: 2.5rem;
  }

  .sl-steps-interactive > li::after {
    content: "";
    position: absolute;
    top: 2rem;
    bottom: 0;
    left: 0.875rem;
    width: 1px;
    background-color: var(--sl-color-hairline-light);
    transform: translateX(-50%);
  }

  .sl-steps-interactive > li:last-child::after {
    display: none;
  }

  .sl-steps-interactive > li:not(.is-timed) {
    counter-increment: steps-counter;
  }

  .sl-steps-interactive > li:not(.is-timed)::before {
    content: counter(steps-counter);
    position: absolute;
    top: 0;
    left: 0;
    width: 1.75rem;
    height: 1.75rem;
    line-height: 1.75rem;
    background-color: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    text-align: center;
    border-radius: 50%;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    box-shadow: inset 0 0 0 1px var(--sl-color-gray-5);
    z-index: 2;
  }

  .sl-steps-interactive > li.is-timed {
    counter-increment: steps-counter;
    padding-inline-start: 0;
  }

  .sl-steps-interactive > li.is-timed::before {
    content: none;
  }

  step-timer {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .timer-pill {
    appearance: none;
    border: none;

    display: inline-flex;
    align-items: center;
    gap: 0.5rem;

    background-color: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    padding: 0.25rem 0.75rem 0.25rem 0.25rem;

    cursor: pointer;
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease;
    z-index: 2;
    font-size: var(--sl-text-xs);
    font-family: var(--sl-font-mono);

    flex-shrink: 0;
    margin-top: -0.25rem;
  }

  .pill-left {
    display: grid;
    place-items: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background-color: var(--sl-color-black);
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease;
    font-weight: 600;
  }

  .pill-right {
    font-weight: bold;
    padding-right: 0.25rem;
  }

  .icon-play,
  .icon-pause {
    display: none;
    font-size: 1rem;
    line-height: 0;
  }

  .timer-pill:is(:hover, .active) {
    background-color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
  }

  :global([data-theme="light"]) .timer-pill:is(:hover, .active) {
    color: var(--sl-color-text-invert);
  }

  .timer-pill:is(:hover, .active) .pill-left {
    background-color: rgba(255, 255, 255, 0.2);
  }

  .timer-pill:hover:not(.active) .step-index {
    display: none;
  }
  .timer-pill:hover:not(.active) .icon-play {
    display: block;
  }

  step-timer.running .step-index {
    display: none;
  }
  step-timer.running .icon-play {
    display: none;
  }
  step-timer.running .icon-pause {
    display: block;
  }

  step-timer.running .time-display {
    font-variant-numeric: tabular-nums;
  }

  .step-content {
    flex-grow: 1;
    min-width: 0;
  }

  .step-content p {
    margin-top: 0;
  }

  .step-content img {
    margin-top: 0.5rem;
    border-radius: 0.5rem;
    max-width: 100%;
    border: 1px solid var(--sl-color-gray-5);
  }
</style>
