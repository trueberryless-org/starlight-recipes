---
import type { StarlightRecipeEntry } from "../libs/content";
import type { Locale } from "../libs/i18n";
import { getRelativeRecipeUrl } from "../libs/page";
import { resolveCuisine } from "../libs/cuisines";

interface Props {
  entry: StarlightRecipeEntry;
  locale: Locale;
}

const { entry, locale } = Astro.props;
const cuisine = resolveCuisine(entry.data.cuisine);
---

{
  cuisine && (
    <span>
      <a href={getRelativeRecipeUrl(`/cuisines/${cuisine.slug}`, locale)}>
        {cuisine.label}
      </a>
    </span>
  )
}

<style>
  span {
    display: inline-block;
    margin-bottom: 0.25rem;
    padding: 0;
  }

  a {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.3rem;
    font-size: var(--sl-text-sm);
    margin-inline: 0.2rem;
    padding: 0.25rem 0.5rem 0.35rem;
    text-decoration: none;
  }

  a:hover {
    border-color: var(--sl-color-gray-2);
  }
</style>
