---
import Default from "@astrojs/starlight/components/MarkdownContent.astro";
import { YouTube } from "astro-embed";

import Cover from "../metadata/Cover.astro";
import Metadata from "../metadata/Metadata.astro";
import Footer from "../metadata/Footer.astro";
import Instructions from "../content/Instructions.astro";
import Ingredients from "../content/Ingredients.astro";
import ShowcaseMediaCard from "../ui/ShowcaseMediaCard.astro";
import RecipeStats from "../content/RecipeStats.astro";
import { getRecipeEntry } from "../../libs/content";
import { isAnyRecipePage } from "../../libs/page";

const { id, locale } = Astro.locals.starlightRoute;

if (!isAnyRecipePage(id)) {
  return null;
}

const { entry, nextLink, prevLink } = await getRecipeEntry(id, locale);

const video = entry.data.video as
  | import("../../libs/video").VideoFrontmatterProcessed
  | undefined;

const videoUrl = video?.url;
const cardTitle = video?.name ?? entry.data.title;
---

<Default>
  {entry.data.cover && <Cover cover={entry.data.cover} />}
  <Metadata {entry} />
  <RecipeStats {entry} />
  <Ingredients {entry} />
  <Instructions {entry} />

  <slot />

  {
    videoUrl && (
      <ShowcaseMediaCard title={cardTitle}>
        <YouTube id={videoUrl} />
      </ShowcaseMediaCard>
    )
  }
  <Footer {entry} {locale} {nextLink} {prevLink} />
</Default>

<style is:global>
  @media print {
    /* Hide interactive/web-only components */
    .yield-controls,
        reset-controller,
        .marker-check,
        .step-input,
        .timer-pill,
        .icon-play,
        .icon-pause,
        .icon-check,
        .starlight-recipes-video-card, /* Or whatever ShowcaseMediaCard renders */
        .prev-next-links,
        footer,
        nav {
      display: none !important;
    }

    /* Ensure the ingredient list doesn't look like a web app */
    .yield-pill {
      background: none !important;
      border: none !important;
      padding: 0 !important;
    }

    /* Show the step numbers clearly since the custom markers are hidden */
    .sl-steps > li {
      padding-inline-start: 3rem !important;
    }

    .sl-steps > li::before {
      display: block !important; /* Force standard list numbering for print */
    }

    /* Hide connector lines for print since interactive markers are hidden */
    .sl-steps > li::after {
      display: none !important;
    }

    /* Keep the images but make sure they don't break across pages */
    img {
      break-inside: avoid;
      max-height: 300px;
    }
  }
</style>
