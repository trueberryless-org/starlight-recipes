---
import Default from "@astrojs/starlight/components/MarkdownContent.astro";
import { YouTube } from "astro-embed";

import Cover from "../metadata/Cover.astro";
import Metadata from "../metadata/Metadata.astro";
import Footer from "../metadata/Footer.astro";
import Instructions from "../content/Instructions.astro";
import Ingredients from "../content/Ingredients.astro";
import ShowcaseMediaCard from "../ui/ShowcaseMediaCard.astro";
import RecipeStats from "../content/RecipeStats.astro";
import { getRecipeEntry } from "../../libs/content";
import { isAnyRecipePage } from "../../libs/page";

const { id, locale } = Astro.locals.starlightRoute;

if (!isAnyRecipePage(id)) {
  return null;
}

const { entry, nextLink, prevLink } = await getRecipeEntry(id, locale);

const video = entry.data.video as
  | import("../../libs/video").VideoFrontmatterProcessed
  | undefined;

const videoUrl = video?.url;
const cardTitle = video?.name ?? entry.data.title;
---

<Default>
  {entry.data.cover && <Cover cover={entry.data.cover} loading={"eager"} />}
  <Metadata {entry} />
  <RecipeStats {entry} />
  <Ingredients {entry} />
  <Instructions {entry} />

  <slot />

  {
    videoUrl && (
      <ShowcaseMediaCard title={cardTitle}>
        <YouTube id={videoUrl} />
      </ShowcaseMediaCard>
    )
  }
  <Footer {entry} {locale} {nextLink} {prevLink} />
</Default>

<style>
  @page {
    margin: 1cm;
    size: auto;
  }

  @media print {
    :global(html),
    :global(body),
    :global(.main-frame),
    :global(main),
    :global(.content-panel),
    :global(.sl-container) {
      min-height: 0 !important;
      height: auto !important;
      margin: 0 !important;
      padding: 0 !important;
    }
    :global(.content-panel) {
      max-width: none !important;
    }
    :global(*) {
      break-after: auto !important;
      page-break-after: auto !important;
    }
    :global(.sl-markdown-content > *:last-child) {
      margin-bottom: 0 !important;
    }
    :global(header) {
      display: none !important;
    }
    :global(nav) {
      display: none !important;
    }
    :global(.sidebar) {
      display: none !important;
    }
    :global(aside) {
      display: none !important;
    }
    :global(.right-sidebar) {
      display: none !important;
    }
    :global(h1) {
      font-size: 1.25rem !important;
      margin-bottom: 0.5rem !important;
    }
    :global(h2) {
      font-size: 1rem !important;
      margin-top: 0.75rem !important;
      margin-bottom: 0.25rem !important;
    }
    :global(h3) {
      font-size: 0.9rem !important;
    }
    :global(a) {
      color: #000 !important;
      text-decoration: none !important;
    }
    :global(a[href^="http"]::after) {
      content: none !important;
    }
  }
</style>
