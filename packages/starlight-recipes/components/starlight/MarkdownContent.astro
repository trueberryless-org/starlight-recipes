---
import Default from "@astrojs/starlight/components/MarkdownContent.astro";
import { YouTube } from "astro-embed";

import Cover from "../metadata/Cover.astro";
import Metadata from "../metadata/Metadata.astro";
import Footer from "../metadata/Footer.astro";
import Instructions from "../content/Instructions.astro";
import Ingredients from "../content/Ingredients.astro";
import ShowcaseMediaCard from "../ui/ShowcaseMediaCard.astro";
import { prepareRecipePageData } from "../../libs/recipe-page";
import RecipeStats from "../content/RecipeStats.astro";

const recipeData = await prepareRecipePageData(
  Astro.locals.starlightRoute,
  Astro.locals.t
);

if (!recipeData) {
  return null;
}

const { entry, nextLink, prevLink, videoMetadata } = recipeData;
const { locale } = Astro.locals.starlightRoute;
---

<Default>
  {entry.data.cover && <Cover cover={entry.data.cover} />}
  <Metadata {entry} {locale} />
  <RecipeStats {entry} />
  <Ingredients {entry} />
  <Instructions {entry} />

  <slot />

  {
    entry.data.video &&
      (videoMetadata ? (
        <ShowcaseMediaCard title={videoMetadata.name}>
          <YouTube id={entry.data.video} />
        </ShowcaseMediaCard>
      ) : (
        <YouTube id={entry.data.video} />
      ))
  }
  <Footer {entry} {locale} {nextLink} {prevLink} />
</Default>
