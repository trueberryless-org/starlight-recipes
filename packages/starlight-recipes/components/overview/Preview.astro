---
import context from "virtual:starlight-recipes-context";

import type { StarlightRecipeEntry } from "../../libs/content";
import type { Locale } from "../../libs/i18n";
import { getPathWithLocale, getRelativeUrl } from "../../libs/page";

import Authors from "./../metadata/Authors.astro";
import Cover from "./../Cover.astro";
import Excerpt from "./Excerpt.astro";
import Rating from "./../Rating.astro";
import CuisineCategoryBlobs from "../metadata/CuisineCategoryBlobs.astro";

interface Props {
  entry: StarlightRecipeEntry;
  locale: Locale;
  bigPreview?: boolean;
}

const { entry, locale, bigPreview } = Astro.props;
const url = getRelativeUrl(`/${getPathWithLocale(entry.id, locale)}`);
---

<a href={url} class={`card-link ${bigPreview ? "big" : "small"}`}>
  <article class="preview-card">
    {
      entry.data.cover && (
        <div class="cover-wrapper">
          <Cover
            cover={entry.data.cover}
            aspectRatio="16/9"
            featured={entry.data.featured ? true : false}
          />
        </div>
      )
    }

    <div class="card-content">
      {!bigPreview && <h2>{entry.data.title}</h2>}
      {
        bigPreview && (
          <div class="big-preview-meta">
            {context.ratingEnabled && (
              <div class="space-between">
                <h2>{entry.data.title}</h2>
                <Rating recipeId={entry.id} />
              </div>
            )}
            <Authors entry={entry} />

            {entry.data.excerpt && (
              <div class="sl-markdown-content excerpt">
                <Excerpt {entry} />
              </div>
            )}
          </div>
        )
      }

      <div class="blobs-wrapper">
        <CuisineCategoryBlobs {entry} {locale} />
      </div>
    </div>
  </article>
</a>

<style>
  /* Reset link styles for the card wrapper */
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.2s ease-in-out;
  }

  .preview-card {
    display: flex;
    flex-direction: column;
    background-color: var(--sl-color-gray-7);
    border-radius: 19px;
    /*overflow: hidden;*/
    height: 100%;
  }

  /* Image Handling */
  .cover-wrapper {
    width: 100%;
    margin: 0;
    transform: scale(1.02);
  }

  /* Internal Content Padding */
  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex-grow: 1; /* Pushes content to fill height if needed */
  }

  /* Typography */
  h2 {
    margin: 0;
    color: var(--sl-color-white);
  }

  .small h2 {
    font-size: 1.25rem;
    line-height: 1.4;
  }

  .big h2 {
    font-size: 1.6rem;
    line-height: 1.3;
  }

  /* Big Preview Specifics */
  .big-preview-meta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .space-between {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .excerpt {
    font-size: 0.95rem;
    color: var(--sl-color-gray-2);
    display: -webkit-box;
    -webkit-line-clamp: 3; /* Limit excerpt to 3 lines */
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blobs-wrapper {
    margin-top: auto; /* Pushes blobs to the bottom of the card */
  }
</style>
