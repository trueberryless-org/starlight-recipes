---
import { getEntryCategory } from "../../libs/categories";
import type { StarlightRecipeEntry } from "../../libs/types";
import type { Locale } from "../../libs/i18n";
import Pill from "../ui/Pill.astro";

interface Props {
  entry: StarlightRecipeEntry;
  locale: Locale;
}

const { entry, locale } = Astro.props;

const category = getEntryCategory(entry);
---

{
  category && (
    <Pill slug={`/category/${category.slug}`} label={category.label} {locale} />
  )
}
